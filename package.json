{
  "name": "claude-docker",
  "version": "1.4.10",
  "private": true,
  "description": "Isolated Claude Code in Docker",
  "license": "MIT",
  "author": "devslaweekq",
  "type": "commonjs",
  "scripts": {
    "build": "bash scripts/docker/build.sh --all",
    "build:claude": "bash scripts/docker/build.sh --claude",
    "build:comfyui": "bash scripts/docker/build.sh --comfyui",
    "build:deb": "bash scripts/deb/build-deb.sh",
    "build:docker": "docker compose -f ./docker-compose.dev.yml build --build-arg HTTP_PROXY= --build-arg HTTPS_PROXY= --build-arg http_proxy= --build-arg https_proxy=",
    "bump": "bash scripts/utils/bump-version.sh",
    "format": "prettier -w .",
    "format:check": "prettier -c .",
    "launcher": "./claude-docker/launcher",
    "push": "bash scripts/docker/push.sh --all",
    "push:claude": "bash scripts/docker/push.sh --claude",
    "push:comfyui": "bash scripts/docker/push.sh --comfyui"
  },
  "devDependencies": {
    "prettier": "^3.9.5",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-sort-json": "^4.2.0"
  }
}
