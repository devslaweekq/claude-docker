#!/usr/bin/env bash
# launcher — host entry point into the claude-docker container. Aware of the directory it was launched from.
#   launcher            — inside a project (subdir of a PROJECT_DIRS root) -> session picker for that project;
#                         at a PROJECT_DIRS root -> full menu;
#                         outside all PROJECT_DIRS (or unset) -> full menu (caller cwd mounted as scratch)
#   launcher --build    — local docker compose build (test changes, no push)
#   launcher --pull     — pull latest image from Docker Hub, then start
#   launcher --comfyui  — start ComfyUI Docker service before session, stop it on exit
#   launcher --headroom — start Headroom proxy before session, stop it on exit
#   launcher --install [--force] — add launcher to PATH (auto claude, or pick name if claude exists); --force re-runs install
#   launcher <args…>    — passthrough: run `claude <args…>` in the container, then exit
#                         (e.g. `claude auth status`, `claude login`, `claude setup-token`)
#
# Image: slaweekq/claude-docker:latest

set -euo pipefail

# caller cwd — before cd into the repo
CALLER_PWD="$(pwd -P)"
# real script path (works via symlink or PATH) -> repo root
SELF="$(readlink -f "$0")"
REPO="$(dirname "$SELF")"

INSTALL_DIR="$HOME/claude-docker"

# Use the installed launcher if it exists, otherwise use the script itself
LAUNCHER="$SELF"
[ -x "$INSTALL_DIR/launcher" ] && LAUNCHER="$INSTALL_DIR/launcher"

# Keep in sync with version in package.json
LAUNCHER_VERSION="1.3.8"

if [ "${1:-}" = "-v" ] || [ "${1:-}" = "--version" ]; then
  echo "claude-docker $LAUNCHER_VERSION"
  exit 0
fi

if [ "${1:-}" = "--install" ]; then
  force_install=0
  [ "${2:-}" = "--force" ] && force_install=1

  [ -d "$HOME/.local/bin" ] || mkdir -p "$HOME/.local/bin"
  _launcher_real="$(readlink -f "$LAUNCHER")"

  _remove_launcher_symlinks() {
    local _f
    for _f in "$HOME/.local/bin/"*; do
      [ -L "$_f" ] || continue
      [ "$(readlink -f "$_f" 2>/dev/null || true)" = "$_launcher_real" ] || continue
      rm -f "$_f"
    done
  }

  # If a symlink in ~/.local/bin already points to this launcher, just refresh it silently
  if [ "$force_install" -eq 0 ]; then
    _existing_cmd=""
    for _f in "$HOME/.local/bin/"*; do
      [ -L "$_f" ] || continue
      [ "$(readlink -f "$_f" 2>/dev/null || true)" = "$_launcher_real" ] || continue
      _existing_cmd="$(basename "$_f")"
      break
    done
    if [ -n "$_existing_cmd" ]; then
      _remove_launcher_symlinks
      ln -sf "$LAUNCHER" "$HOME/.local/bin/$_existing_cmd"
      echo "OK: $HOME/.local/bin/$_existing_cmd -> $LAUNCHER (updated)"
      echo "$_existing_cmd" > /tmp/claude-docker-chosen-cmd 2>/dev/null || true
      exit 0
    fi
  fi

  native_cli=0
  native_where=""
  for v in "$HOME/.local/share/claude/versions/"*; do
    [ -e "$v" ] || continue
    native_cli=1
    native_where="$v"
    break
  done
  if [ "$native_cli" -eq 0 ]; then
    native="$(command -v claude 2>/dev/null || true)"
    for p in "$HOME/.local/bin/claude" /usr/local/bin/claude; do
      [ -n "$native" ] && break
      [ -e "$p" ] && native="$p"
    done
    if [ -n "$native" ] && [ "$(readlink -f "$native" 2>/dev/null || echo "$native")" != "$_launcher_real" ]; then
      native_cli=1
      native_where="$native"
    fi
  fi

  if [ "$native_cli" -eq 1 ]; then
    cat <<EOF

==> Add command to PATH

claude is already installed ($native_where).
Choose a command name for claude-docker:

  1) cladock
  2) custom name
  3) skip

EOF
    read -rp "Choice [1-3, default 1]: " ans
    case "${ans:-1}" in
      1) cmd=cladock ;;
      2) read -rp "Command name: " cmd ;;
      3) echo "Skipped PATH setup."; exit 0 ;;
      *) echo "Invalid choice — skipped." >&2; exit 0 ;;
    esac
    [ -n "${cmd:-}" ] || { echo "Skipped PATH setup."; exit 0; }
  else
    cmd=claude
  fi

  _remove_launcher_symlinks
  ln -sf "$LAUNCHER" "$HOME/.local/bin/$cmd"
  echo "OK: $HOME/.local/bin/$cmd -> $LAUNCHER"
  echo "$cmd" > /tmp/claude-docker-chosen-cmd 2>/dev/null || true
  exit 0
fi

cd "$REPO"

CLAUDE_HOME="${CLAUDE_HOME:-$HOME/claude-docker/home}"
[ -d "$CLAUDE_HOME/scratch" ] || mkdir -p "$CLAUDE_HOME/scratch"
export CLAUDE_HOME
COMFYUI_HOME="${COMFYUI_HOME:-$(dirname "$CLAUDE_HOME")/comfyui}"
export COMFYUI_HOME
HEADROOM_HOME="${HEADROOM_HOME:-$(dirname "$CLAUDE_HOME")/headroom}"
export HEADROOM_HOME
[ -d "$HEADROOM_HOME/.headroom" ] || mkdir -p "$HEADROOM_HOME/.headroom"

if [ ! -f .env ]; then
  echo "Missing .env — copy .env.example, set PROJECT_DIRS, then retry:" >&2
  echo "  cp .env.example .env && chmod 600 .env" >&2
  exit 1
fi

force_pull=0
force_build=0
start_comfyui=0
start_headroom=0
passthrough_args=()                           # claude args forwarded into the container (claude auth status, login, …)

for a in "$@"; do
  case "$a" in
    --pull)      force_pull=1 ;;
    --build)     force_build=1 ;;
    --comfyui)   start_comfyui=1 ;;
    --headroom)  start_headroom=1 ;;
    *)           passthrough_args+=("$a") ;;
  esac
done

# --- PROJECT_DIRS from .env: comma-separated parent dirs; each immediate subdir → /workspace/<name> ---
proj="$(grep -E '^PROJECT_DIRS=' .env | tail -1 | cut -d= -f2- || true)"   # || true: no match must not trip set -e/pipefail
proj="${proj%% #*}"                           # strip inline comment
proj="${proj#"${proj%%[![:space:]]*}"}"       # trim leading space
proj="${proj%"${proj##*[![:space:]]}"}"       # trim trailing space
proj="${proj#\"}"; proj="${proj%\"}"          # unquote (last, so comment/space stripping can't leave a stray quote)

here="$(readlink -f "$CALLER_PWD" 2>/dev/null || echo "$CALLER_PWD")"
vol_opts=()            # -v flags, one per mounted project subdir
mode_arg=()            # claude-launch arg: empty → full menu, /workspace/… → session picker
scratch_run_opts=()    # extra docker compose run flags for the scratch bind-mount
at_root=0              # caller cwd is a PROJECT_DIRS parent → full menu, no scratch bind-mount

# Single pass: mount every subdir, and meanwhile detect which one (if any) holds the caller cwd.
IFS=',' read -ra _roots <<< "$proj"
for _r in "${_roots[@]}"; do
  _r="${_r#"${_r%%[![:space:]]*}"}"; _r="${_r%"${_r##*[![:space:]]}"}"   # trim
  [ -n "$_r" ] || continue                                              # skip empty entries (a,,b / trailing comma)
  _r="$(readlink -f "${_r%/}" 2>/dev/null || true)"
  [ -d "$_r" ] || { echo "PROJECT_DIRS: '${_r:-<empty>}' is not a valid directory" >&2; exit 1; }
  [ "$here" = "$_r" ] && at_root=1
  for _s in "$_r"/*/; do
    [ -d "$_s" ] || continue
    _s="${_s%/}"; _n="$(basename "$_s")"
    vol_opts+=(-v "$_s:/workspace/$_n")
    if [ "$here" = "$_s" ] || [ "${here#"$_s"/}" != "$here" ]; then
      mode_arg=("/workspace/$_n${here#"$_s"}")  # at/inside a subdir → session picker for it
    fi
  done
done
unset _roots _r _s _n

# Outside every project and not at a parent root → bind-mount cwd so the menu's "scratch" lands here.
if [ ${#mode_arg[@]} -eq 0 ] && [ "$at_root" -eq 0 ]; then
  scratch_run_opts=(-v "$here:/home/node/scratch:rw" -e SCRATCH_BIND_MOUNT=1)
fi

# Clipboard forwarding: prefer Wayland (wl-copy), fall back to X11 (xclip).
# Claude Code selects: wl-copy > xclip > OSC 52. OSC 52 has UTF-8 encoding issues in
# VS Code xterm.js, producing garbled Cyrillic on paste — so we avoid it by forwarding
# the compositor socket so the container can reach the native clipboard.
x11_run_opts=()
_xdg="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
_wl_sock="$_xdg/${WAYLAND_DISPLAY:-wayland-0}"
if [ -n "${WAYLAND_DISPLAY:-}" ] && [ -S "$_wl_sock" ]; then
  # Wayland: mount only the socket file; pass XDG_RUNTIME_DIR so wl-copy can find it
  x11_run_opts+=(-e "WAYLAND_DISPLAY=$WAYLAND_DISPLAY" -e "XDG_RUNTIME_DIR=$_xdg" -v "$_wl_sock:$_wl_sock")
elif [ -n "${DISPLAY:-}" ] && [ -d /tmp/.X11-unix ]; then
  # X11 fallback: mount socket dir + pass auth cookie
  x11_run_opts+=(-e "DISPLAY=$DISPLAY" -v /tmp/.X11-unix:/tmp/.X11-unix)
  if [ -n "${XAUTHORITY:-}" ] && [ -f "$XAUTHORITY" ]; then
    x11_run_opts+=(-v "$XAUTHORITY:/tmp/.xdocker_auth:ro" -e "XAUTHORITY=/tmp/.xdocker_auth")
  fi
fi
unset _xdg _wl_sock

IMAGE=slaweekq/claude-docker:latest

# --pull / --build: stop running session before replacing the image
if [ "$force_pull" -eq 1 ] || [ "$force_build" -eq 1 ]; then
  mapfile -t running < <(docker ps -q --filter label=claude-docker.role=session 2>/dev/null || true)
  if [ ${#running[@]} -gt 0 ]; then
    docker stop "${running[@]}"
  fi
fi

if [ "$force_pull" -eq 1 ] || ! docker image inspect "$IMAGE" >/dev/null 2>&1; then
  docker compose -f ./docker-compose.yml pull
fi

# Build image only on explicit --build (regular users always pull a prebuilt image)
if [ "$force_build" -eq 1 ]; then
  docker compose -f ./docker-compose.dev.yml build \
    --build-arg HTTP_PROXY= --build-arg HTTPS_PROXY= \
    --build-arg http_proxy= --build-arg https_proxy=
fi

# Ref-count for multi-session service sharing: each session drops a PID file; last one out stops the service.
_SVC_LOCK_DIR="${TMPDIR:-/tmp}/claude-svc-sessions"

_svc_register() {
  mkdir -p "$_SVC_LOCK_DIR/$1"
  touch "$_SVC_LOCK_DIR/$1/$$"
}

_svc_unregister() {
  rm -f "$_SVC_LOCK_DIR/$1/$$"
}

_svc_in_use() {
  local dir="$_SVC_LOCK_DIR/$1" f pid
  [ -d "$dir" ] || return 1
  for f in "$dir"/*; do
    [ -e "$f" ] || continue
    pid="$(basename "$f")"
    if kill -0 "$pid" 2>/dev/null; then
      return 0
    else
      rm -f "$f"   # stale entry from a session that crashed without cleanup
    fi
  done
  return 1
}

# ComfyUI: start Docker service on --comfyui (only for interactive sessions, not passthrough)
if [ "$start_comfyui" -eq 1 ] && [ ${#passthrough_args[@]} -eq 0 ]; then
  _svc_register comfyui
  if curl -sf http://localhost:8188/system_stats >/dev/null 2>&1; then
    echo "==> ComfyUI already running at localhost:8188 — skipping start"
  else
    echo "==> Starting ComfyUI Docker service…"
    docker compose -f ./docker-compose.yml --profile comfyui up -d comfyui
    for _i in $(seq 1 60); do
      curl -sf http://localhost:8188/system_stats >/dev/null 2>&1 && break
      sleep 2
    done
    echo "    ComfyUI ready at localhost:8188"
  fi
fi

if [ "$start_headroom" -eq 1 ] && [ ${#passthrough_args[@]} -eq 0 ]; then
  _svc_register headroom
  if curl -sf http://localhost:8787/readyz >/dev/null 2>&1; then
    echo "==> Headroom already running at localhost:8787 — skipping start"
  else
    echo "==> Starting Headroom Docker service…"
    docker compose -f ./docker-compose.yml --profile headroom up -d headroom
    for _i in $(seq 1 60); do
      curl -sf http://localhost:8787/readyz >/dev/null 2>&1 && break
      sleep 2
    done
    echo "    Headroom ready at localhost:8787"
  fi
fi

_cleanup_optional_services() {
  if [ "$start_comfyui" -eq 1 ] && [ ${#passthrough_args[@]} -eq 0 ]; then
    _svc_unregister comfyui
    if ! _svc_in_use comfyui; then
      echo "==> Stopping ComfyUI Docker service…"
      docker compose -f ./docker-compose.yml stop comfyui 2>/dev/null || true
    fi
  fi
  if [ "$start_headroom" -eq 1 ] && [ ${#passthrough_args[@]} -eq 0 ]; then
    _svc_unregister headroom
    if ! _svc_in_use headroom; then
      echo "==> Stopping Headroom Docker service…"
      docker compose -f ./docker-compose.yml stop headroom 2>/dev/null || true
    fi
  fi
}
trap _cleanup_optional_services EXIT

# Passthrough: forward any unrecognized args straight to `claude` in a throwaway container,
# then exit with claude's status. Reserved flags (--install/--pull/--build) never reach here.
# Allocate a TTY only when stdin+stdout are terminals (interactive `claude login`);
# pass -T otherwise so piped output stays clean (`claude auth status | grep …`).
if [ ${#passthrough_args[@]} -gt 0 ]; then
  tty_opts=()
  { [ -t 0 ] && [ -t 1 ]; } || tty_opts=(-T)
  exec docker compose -f ./docker-compose.yml run --rm "${tty_opts[@]}" "${x11_run_opts[@]}" \
    --label claude-docker.role=exec claude --exec "${passthrough_args[@]}"
fi

if [ "$start_comfyui" -eq 1 ] || [ "$start_headroom" -eq 1 ]; then
  # Without exec so the shell survives to run the EXIT trap (stops optional services on session end)
  docker compose -f ./docker-compose.yml run --rm --label claude-docker.role=session "${vol_opts[@]}" "${scratch_run_opts[@]}" "${x11_run_opts[@]}" claude "${mode_arg[@]}"
else
  exec docker compose -f ./docker-compose.yml run --rm --label claude-docker.role=session "${vol_opts[@]}" "${scratch_run_opts[@]}" "${x11_run_opts[@]}" claude "${mode_arg[@]}"
fi
