{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autoMode": {
    "allow": [
      "$defaults",
      "Allow spawning subagents (Agent) for parallel research and codebase exploration",
      "Allow WebSearch and WebFetch for documentation lookup and web research"
    ],
    "environment": [
      "Local development workspaces and git repositories on this machine",
      "Parallel subagents for research, exploration, and documentation tasks are routine"
    ]
  },
  "enabledPlugins": {
    "claude-mem@thedotmack": true,
    "figma@claude-plugins-official": false,
    "superpowers@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "git",
        "url": "https://github.com/anthropics/claude-plugins-official.git"
      }
    },
    "thedotmack": {
      "source": {
        "source": "git",
        "url": "https://github.com/thedotmack/claude-mem.git"
      }
    }
  },
  "gitAttribution": true,
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": ["Read(.env.example)", "WebSearch", "WebFetch"],
    "defaultMode": "auto",
    "deny": [
      "Read(.env*)",
      "Read(./secrets/**)",
      "Read(./**/credentials.json)",
      "Read(./**/service-account.json)",
      "Bash(rm -rf /)",
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.production)",
      "Read(**/.env.development)",
      "Read(**/.env.staging)",
      "Read(**/.env.test)"
    ]
  },
  "skipWorkflowUsageWarning": true,
  "spinnerTipsEnabled": false,
  "theme": "dark-ansi",
  "verbose": false,
  "viewMode": "focus"
}
